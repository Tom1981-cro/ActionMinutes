<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
        <key>CFBundleDevelopmentRegion</key>
        <string>en</string>
        <key>CFBundleDisplayName</key>
        <string>ActionMinutes</string>
        <key>CFBundleExecutable</key>
        <string>$(EXECUTABLE_NAME)</string>
        <key>CFBundleIdentifier</key>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
        <key>CFBundleInfoDictionaryVersion</key>
        <string>6.0</string>
        <key>CFBundleName</key>
        <string>$(PRODUCT_NAME)</string>
        <key>CFBundlePackageType</key>
        <string>APPL</string>
        <key>CFBundleShortVersionString</key>
        <string>$(MARKETING_VERSION)</string>
        <key>CFBundleVersion</key>
        <string>$(CURRENT_PROJECT_VERSION)</string>
        <key>LSRequiresIPhoneOS</key>
        <true/>
        <key>UILaunchStoryboardName</key>
        <string>LaunchScreen</string>
        <key>UIMainStoryboardFile</key>
        <string>Main</string>
        <key>UIRequiredDeviceCapabilities</key>
        <array>
                <string>armv7</string>
        </array>
        <key>UISupportedInterfaceOrientations</key>
        <array>
                <string>UIInterfaceOrientationPortrait</string>
                <string>UIInterfaceOrientationLandscapeLeft</string>
                <string>UIInterfaceOrientationLandscapeRight</string>
        </array>
        <key>UISupportedInterfaceOrientations~ipad</key>
        <array>
                <string>UIInterfaceOrientationPortrait</string>
                <string>UIInterfaceOrientationPortraitUpsideDown</string>
                <string>UIInterfaceOrientationLandscapeLeft</string>
                <string>UIInterfaceOrientationLandscapeRight</string>
        </array>
        <key>UIViewControllerBasedStatusBarAppearance</key>
        <true/>
        
        <!-- Camera Permission -->
        <key>NSCameraUsageDescription</key>
        <string>ActionMinutes needs camera access to scan and import handwritten notes</string>
        
        <!-- Photo Library Permissions -->
        <key>NSPhotoLibraryUsageDescription</key>
        <string>ActionMinutes needs photo library access to import images of your notes</string>
        <key>NSPhotoLibraryAddUsageDescription</key>
        <string>ActionMinutes needs permission to save captured images to your photo library</string>
        
        <!-- Microphone Permission (for future audio notes) -->
        <key>NSMicrophoneUsageDescription</key>
        <string>ActionMinutes needs microphone access for voice recording features</string>
        
        <!-- Face ID Permission (for app lock feature) -->
        <key>NSFaceIDUsageDescription</key>
        <string>ActionMinutes uses Face ID for secure app authentication</string>
        
        <!-- Local Notifications -->
        <key>UIBackgroundModes</key>
        <array>
                <string>fetch</string>
                <string>remote-notification</string>
        </array>
        
        <!-- App Transport Security - Allow all connections for development -->
        <key>NSAppTransportSecurity</key>
        <dict>
                <key>NSAllowsArbitraryLoads</key>
                <true/>
        </dict>
        
        <!-- URL Schemes for Deep Linking -->
        <key>CFBundleURLTypes</key>
        <array>
                <dict>
                        <key>CFBundleURLName</key>
                        <string>com.actionminutes.app</string>
                        <key>CFBundleURLSchemes</key>
                        <array>
                                <string>actionminutes</string>
                        </array>
                </dict>
        </array>
        
        <!-- Associated Domains for Universal Links (add your domain) -->
        <!-- This needs to be configured in Xcode Signing & Capabilities -->
        
        <!-- Status Bar Style -->
        <key>UIStatusBarStyle</key>
        <string>UIStatusBarStyleLightContent</string>
        
        <!-- Prevent screen capture (optional, for security) -->
        <key>UIFileSharingEnabled</key>
        <false/>
        
        <!-- Launch screen configuration -->
        <key>UILaunchStoryboardName</key>
        <string>LaunchScreen</string>
</dict>
</plist>
