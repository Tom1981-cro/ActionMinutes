# ActionMinutes Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE (Required)
# =============================================================================
DATABASE_URL=postgresql://user:password@host:5432/database

# =============================================================================
# AI CONFIGURATION (Optional - enables AI extraction and draft generation)
# =============================================================================
# Provider: 'openai' or 'google'
AI_PROVIDER=openai
# Your API key from the provider
AI_API_KEY=sk-your-openai-api-key
# Alternative: Direct OpenAI key (if AI_PROVIDER not set)
OPENAI_API_KEY=sk-your-openai-api-key

# =============================================================================
# GMAIL INTEGRATION (Optional - enables Gmail OAuth for sending drafts)
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=https://your-app.com/api/oauth/google/callback

# =============================================================================
# OUTLOOK INTEGRATION (Optional - enables Outlook OAuth for sending drafts)
# =============================================================================
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URL=https://your-app.com/api/oauth/microsoft/callback

# =============================================================================
# SESSION & SECURITY (Required for production)
# =============================================================================
SESSION_SECRET=your-secure-random-session-secret

# =============================================================================
# MOBILE BUILD (Optional - enables Capacitor mobile builds)
# =============================================================================
CAPACITOR_ENABLED=false

# =============================================================================
# FEATURE FLAGS (Optional - all default to true except reminders)
# Set to 'true' or 'false' to enable/disable features
# =============================================================================
AI_FEATURE_ENABLED=true
INTEGRATIONS_FEATURE_ENABLED=true
PERSONAL_FEATURE_ENABLED=true
TEAM_FEATURE_ENABLED=true
REMINDERS_FEATURE_ENABLED=false

# =============================================================================
# SERVER (Optional)
# =============================================================================
PORT=5000
NODE_ENV=development
